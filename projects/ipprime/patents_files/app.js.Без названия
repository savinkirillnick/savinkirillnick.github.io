/**
 * IP PRIME — Main application script
 * Vanilla JS, modular structure, no global leaks
 */
(function () {
  'use strict';

  /* ============================
     HEADER & NAVIGATION
  ============================ */
  const header = document.getElementById('header');
  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobileMenu');
  const mobileCta = document.getElementById('mobileCta');

  // Scroll-based header styling
  let lastScroll = 0;
  function handleScroll() {
    const y = window.scrollY;
    if (y > 60) {
      header.classList.add('header--scrolled');
    } else {
      header.classList.remove('header--scrolled');
    }
    // Mobile CTA
    if (mobileCta) {
      if (y > 400) {
        mobileCta.classList.remove('translate-y-full');
        mobileCta.classList.add('translate-y-0');
      } else {
        mobileCta.classList.add('translate-y-full');
        mobileCta.classList.remove('translate-y-0');
      }
    }
    lastScroll = y;
  }
  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  // Burger toggle
  if (burger && mobileMenu) {
    burger.addEventListener('click', function () {
      burger.classList.toggle('active');
      const open = mobileMenu.classList.contains('opacity-0');
      if (open) {
        mobileMenu.classList.remove('opacity-0', 'invisible');
        mobileMenu.classList.add('opacity-100', 'visible');
        document.body.style.overflow = 'hidden';
      } else {
        mobileMenu.classList.add('opacity-0', 'invisible');
        mobileMenu.classList.remove('opacity-100', 'visible');
        document.body.style.overflow = '';
      }
    });

    // Close on link click
    mobileMenu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        burger.classList.remove('active');
        mobileMenu.classList.add('opacity-0', 'invisible');
        mobileMenu.classList.remove('opacity-100', 'visible');
        document.body.style.overflow = '';
      });
    });
  }

  /* ============================
     SMOOTH SCROLL
  ============================ */
  document.querySelectorAll('a[href^="#"]').forEach(function (a) {
    a.addEventListener('click', function (e) {
      const id = this.getAttribute('href');
      if (id === '#') return;
      const el = document.querySelector(id);
      if (el) {
        e.preventDefault();
        el.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  /* ============================
     SCROLL REVEAL (Intersection Observer)
  ============================ */
  const revealObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        // Staggered delay for siblings
        const siblings = entry.target.parentElement.querySelectorAll('.reveal');
        let idx = Array.from(siblings).indexOf(entry.target);
        entry.target.style.transitionDelay = (idx * 80) + 'ms';
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

  document.querySelectorAll('.reveal').forEach(function (el) {
    revealObserver.observe(el);
  });

  /* ============================
     COUNTER ANIMATION
  ============================ */
  function animateCounter(el) {
    const target = parseInt(el.dataset.count, 10);
    const duration = 2000;
    const start = performance.now();
    function tick(now) {
      const progress = Math.min((now - start) / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3);
      el.textContent = Math.round(target * ease);
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const counterObserver = new IntersectionObserver(function (entries) {
    entries.forEach(function (entry) {
      if (entry.isIntersecting) {
        animateCounter(entry.target);
        counterObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  document.querySelectorAll('.counter').forEach(function (el) {
    counterObserver.observe(el);
  });

  /* ============================
     FAQ ACCORDION
  ============================ */
  document.querySelectorAll('.faq-toggle').forEach(function (btn) {
    btn.addEventListener('click', function () {
      const isOpen = btn.classList.contains('active');
      // Close all
      document.querySelectorAll('.faq-toggle').forEach(function (b) {
        b.classList.remove('active');
        b.setAttribute('aria-expanded', 'false');
        b.nextElementSibling.style.maxHeight = '0';
      });
      // Open clicked (if was closed)
      if (!isOpen) {
        btn.classList.add('active');
        btn.setAttribute('aria-expanded', 'true');
        btn.nextElementSibling.style.maxHeight = btn.nextElementSibling.scrollHeight + 'px';
      }
    });
  });

  /* ============================
     PHONE MASK
  ============================ */
  function applyPhoneMask(input) {
    function format(value) {
      let digits = value.replace(/\D/g, '');
      if (digits.length > 0 && digits[0] === '8') digits = '7' + digits.slice(1);
      if (digits.length > 0 && digits[0] !== '7') digits = '7' + digits;
      var result = '+7';
      if (digits.length > 1) result += ' (' + digits.slice(1, 4);
      if (digits.length >= 4) result += ') ';
      if (digits.length > 4) result += digits.slice(4, 7);
      if (digits.length > 7) result += '-' + digits.slice(7, 9);
      if (digits.length > 9) result += '-' + digits.slice(9, 11);
      return result;
    }

    input.addEventListener('input', function () {
      var pos = input.selectionStart;
      var old = input.value;
      input.value = format(input.value);
      // Try to keep cursor in a reasonable position
      if (input.value.length > old.length) pos++;
      input.setSelectionRange(pos, pos);
    });

    input.addEventListener('focus', function () {
      if (!input.value) input.value = '+7';
    });

    input.addEventListener('blur', function () {
      if (input.value === '+7' || input.value === '+7 (') input.value = '';
    });
  }

  document.querySelectorAll('.phone-mask, input[type="tel"]').forEach(applyPhoneMask);

  /* ============================
     QUIZ SYSTEM
  ============================ */
  var quizStep = 1;
  var totalSteps = 4;
  var progressBar = document.getElementById('quizProgress');
  var quizNav = document.getElementById('quizNav');
  var prevBtn = document.getElementById('quizPrev');
  var nextBtn = document.getElementById('quizNext');
  var resultPrice = document.getElementById('quizResultPrice');

  function showSlide(step) {
    document.querySelectorAll('.quiz-slide').forEach(function (s) {
      s.classList.add('hidden');
      s.classList.remove('active');
    });
    var target = document.querySelector('[data-slide="' + step + '"]');
    if (target) {
      target.classList.remove('hidden');
      target.classList.add('active');
    }
    // Update progress
    if (typeof step === 'number') {
      progressBar.style.width = (step / totalSteps * 100) + '%';
      document.querySelectorAll('[data-step-dot]').forEach(function (dot) {
        var s = parseInt(dot.dataset.stepDot, 10);
        dot.className = 'w-8 h-8 rounded-full flex items-center justify-center text-xs font-semibold border-2 transition-all duration-300';
        if (s < step) dot.classList.add('bg-gold', 'border-gold', 'text-dark');
        else if (s === step) dot.classList.add('bg-gold', 'border-gold', 'text-dark');
        else dot.classList.add('bg-transparent', 'border-edge-gold', 'text-lite-muted');
      });
    }
    // Prev/Next visibility
    if (prevBtn) prevBtn.style.visibility = step > 1 ? 'visible' : 'hidden';
    if (nextBtn) nextBtn.textContent = step === totalSteps ? 'Результат' : 'Далее';
    if (quizNav) quizNav.style.display = step === 'result' ? 'none' : '';
  }

  function calculatePrice() {
    var prices = { invention: 100000, utility: 80000, trademark: 20000, design: 30000 };
    var q1 = document.querySelector('input[name="q1"]:checked');
    var q2 = document.querySelector('input[name="q2"]:checked');
    var q3 = document.querySelector('input[name="q3"]:checked');
    var q4 = document.querySelector('input[name="q4"]:checked');
    var total = q1 ? (prices[q1.value] || 50000) : 50000;
    if (q2) {
      if (q2.value === 'search_yes') total += 20000;
    }
    if (q3) {
      if (q3.value === 'cis') total += 30000;
      else if (q3.value === 'international') total += 60000;
    }
    if (q4) {
      if (q4.value === 'urgent') total += 30000;
      else if (q4.value === 'priority') total += 15000;
    }
    return total;
  }

  // Update urgency time text based on selected service type
  function updateUrgencyText() {
    var q1 = document.querySelector('input[name="q1"]:checked');
    var timeEl = document.querySelector('.urgency-time');
    if (!timeEl || !q1) return;
    var times = {
      invention: '6-12 месяцев',
      utility: '3-4 месяца',
      trademark: '7-11 месяцев',
      design: '3-4 месяца'
    };
    timeEl.textContent = times[q1.value] || '6-12 месяцев';
  }

  // Auto-advance on radio select
  document.querySelectorAll('.quiz-slide input[type="radio"]').forEach(function (radio) {
    radio.addEventListener('change', function () {
      // Update urgency text when q1 changes
      if (this.name === 'q1') updateUrgencyText();
      setTimeout(function () {
        if (quizStep < totalSteps) {
          quizStep++;
          showSlide(quizStep);
        } else if (quizStep === totalSteps) {
          // Show result
          var price = calculatePrice();
          if (resultPrice) resultPrice.textContent = 'от ' + price.toLocaleString('ru-RU') + ' \u20BD';
          showSlide('result');
        }
      }, 300);
    });
  });

  if (nextBtn) {
    nextBtn.addEventListener('click', function () {
      // Check if current step has selection
      var checked = document.querySelector('input[name="q' + quizStep + '"]:checked');
      if (!checked) return;
      if (quizStep < totalSteps) {
        quizStep++;
        showSlide(quizStep);
      } else {
        var price = calculatePrice();
        if (resultPrice) resultPrice.textContent = 'от ' + price.toLocaleString('ru-RU') + ' \u20BD';
        showSlide('result');
      }
    });
  }

  if (prevBtn) {
    prevBtn.addEventListener('click', function () {
      if (quizStep > 1) {
        quizStep--;
        showSlide(quizStep);
      }
    });
  }

  /* ============================
     FORM HANDLING
  ============================ */
  function handleFormSubmit(form, modal) {
    if (!form) return;
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      var btn = form.querySelector('button[type="submit"]');
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Отправка...';
      }
      // Simulate send
      setTimeout(function () {
        form.reset();
        if (btn) {
          btn.disabled = false;
          btn.textContent = btn.dataset.originalText || 'Отправить';
        }
        openModal(modal || 'successModal');
      }, 600);
    });
    // Store original button text
    var btn = form.querySelector('button[type="submit"]');
    if (btn) btn.dataset.originalText = btn.textContent;
  }

  handleFormSubmit(document.getElementById('ctaForm'), 'successModal');
  handleFormSubmit(document.getElementById('quizForm'), 'successModal');
  handleFormSubmit(document.getElementById('exitForm'), 'successModal');

  /* ============================
     MODALS
  ============================ */
  window.openModal = function (id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.remove('opacity-0', 'invisible');
    modal.classList.add('opacity-100', 'visible');
    document.body.style.overflow = 'hidden';
  };

  window.closeModal = function (id) {
    var modal = document.getElementById(id);
    if (!modal) return;
    modal.classList.add('opacity-0', 'invisible');
    modal.classList.remove('opacity-100', 'visible');
    document.body.style.overflow = '';
  };

  // Close modal on backdrop click
  document.querySelectorAll('[id$="Modal"]').forEach(function (modal) {
    modal.addEventListener('click', function (e) {
      if (e.target === modal) closeModal(modal.id);
    });
  });

  // Close modal on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('[id$="Modal"]').forEach(function (modal) {
        if (!modal.classList.contains('invisible')) closeModal(modal.id);
      });
    }
  });

  /* ============================
     EXIT INTENT (DISABLED)
  ============================ */
  // Exit intent modal removed per client request
  // var exitShown = false;
  // document.addEventListener('mouseout', function (e) {
  //   if (!exitShown && e.clientY <= 0) {
  //     exitShown = true;
  //     openModal('exitModal');
  //     try { sessionStorage.setItem('exitShown', '1'); } catch (ex) {}
  //   }
  // });

  /* ============================
     FLOATING SOCIALS
  ============================ */
  var floatToggle = document.getElementById('floatSocialsToggle');
  var floatMenu = document.getElementById('floatMenu');

  if (floatToggle && floatMenu) {
    floatToggle.addEventListener('click', function () {
      var open = floatMenu.classList.contains('opacity-0');
      if (open) {
        floatMenu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        floatMenu.classList.add('opacity-100', 'visible', 'translate-y-0');
        floatToggle.querySelector('.float-icon-open').classList.add('hidden');
        floatToggle.querySelector('.float-icon-close').classList.remove('hidden');
      } else {
        floatMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
        floatMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        floatToggle.querySelector('.float-icon-open').classList.remove('hidden');
        floatToggle.querySelector('.float-icon-close').classList.add('hidden');
      }
    });

    // Close on click outside
    document.addEventListener('click', function (e) {
      if (!e.target.closest('#floatSocials')) {
        floatMenu.classList.add('opacity-0', 'invisible', 'translate-y-2');
        floatMenu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        floatToggle.querySelector('.float-icon-open').classList.remove('hidden');
        floatToggle.querySelector('.float-icon-close').classList.add('hidden');
      }
    });
  }

  /* ============================
     PARALLAX (Desktop only)
  ============================ */
  var heroVisual = document.getElementById('heroVisual');
  if (heroVisual && window.innerWidth > 1024) {
    document.addEventListener('mousemove', function (e) {
      var x = (e.clientX / window.innerWidth - 0.5) * 20;
      var y = (e.clientY / window.innerHeight - 0.5) * 20;
      heroVisual.style.transform = 'translate(' + x + 'px, ' + y + 'px)';
    });
  }

  /* ============================
     GLOBAL HELPERS (for onclick handlers)
  ============================ */
  window.scrollToForm = function () {
    var cta = document.getElementById('cta');
    if (cta) cta.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

  window.scrollToQuiz = function () {
    var quiz = document.getElementById('quiz');
    if (quiz) quiz.scrollIntoView({ behavior: 'smooth', block: 'start' });
  };

})();
